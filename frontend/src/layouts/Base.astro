<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dispatra - On-chain Delivery Escrow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: #0a0a0a;
        color: #ededed;
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      main { min-height: 100vh; }
      a { color: #3b82f6; }
      input, select, textarea {
        background: #1a1a1a;
        border: 1px solid #333;
        color: #ededed;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-size: 0.95rem;
        width: 100%;
        outline: none;
        transition: border-color 0.2s;
        font-family: inherit;
      }
      input:focus, select:focus, textarea:focus { border-color: #3b82f6; }
      input::placeholder { color: #666; }
      button[type="submit"], button:not([type]) {
        background: #3b82f6;
        color: white;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        font-size: 0.95rem;
        cursor: pointer;
        transition: background 0.2s;
        width: 100%;
        font-family: inherit;
      }
      button:hover { background: #2563eb; }
      button:disabled { background: #333; color: #666; cursor: not-allowed; }
      hr { border: none; border-top: 1px solid #333; margin: 2rem 0; }
      p { line-height: 1.6; }
      .leaflet-container { background: #111 !important; }
      @media (max-width: 768px) {
        .mobile-full { width: 100% !important; }
        .mobile-stack { flex-direction: column !important; }
        .mobile-center { text-align: center !important; }
      }
      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
      }
    </style>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap');
      
      :root {
        --rk-connectbutton-font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }
      
      .rk-connectButton,
      [data-rk] button {
        font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif !important;
      }
      
      .rk-modal {
        border-radius: 12px !important;
      }
    </style>
    <slot name="head" />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
